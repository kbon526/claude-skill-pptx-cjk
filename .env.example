# pptx-cjk skill 配置 — 复制为 .env 后填入真实值
# .env 文件不会被 git 提交(已在 .gitignore 排除)

# ── OpenAIImageProvider 配置 ──────────────────────────────
# 用 OpenAI Image API 兼容服务生成配图(可以是 OpenAI 官方或国内 relay)
PPTX_CJK_IMAGE_API_BASE=https://api.openai.com/v1
PPTX_CJK_IMAGE_API_KEY=sk-...
PPTX_CJK_IMAGE_MODEL=gpt-image-1
# 默认图片质量与尺寸(可在调用时覆盖)
PPTX_CJK_IMAGE_DEFAULT_SIZE=1024x1024
PPTX_CJK_IMAGE_DEFAULT_QUALITY=medium

# ── LocalAssetProvider 配置(可选) ────────────────────────
# 本地素材库目录,用于 LocalAssetProvider 检索
PPTX_CJK_ASSET_DIR=~/Desktop/asset_library
